# npm retry/timeout tuning for less-flaky Docker builds.
# Default fetch-retries=2 + 10s timeout makes a single ECONNRESET
# fatal; these values are the same ones the npm CLI team recommends
# for CI / containerized installs.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
