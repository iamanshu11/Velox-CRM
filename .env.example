# ─────────────────────────────────────────────────────────────────────────────
#  Velox-CRM  —  Root environment variables for docker-compose
#
#  1. Copy this file:   cp .env.example .env
#  2. Fill in the values below (especially JWT_SECRET)
#  3. Run:              docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password used by both the postgres container and the backend
DB_PASSWORD=postgres

# REQUIRED — change this to a long random string before going to production
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret_string

# Backend API URL baked into the React bundle at build time.
# For local Docker: keep http://localhost:5000/api
# For production:   set to your public API URL (e.g. https://api.yourapp.com/api)
VITE_API_URL=http://localhost:5000/api
